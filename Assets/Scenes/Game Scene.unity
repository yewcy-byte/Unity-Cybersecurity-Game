  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=150%><b>Cross-Site Scripting (XSS)</b></size>\r\n\r\n1. <color=#569CD6><b>Action:</b></color>
    Stop injecting raw strings into <color=#4EC9B0>innerHTML</color>. Instead, select
    the target element and use <color=#DCDCAA>textContent</color> to assign the user\u2019s
    input.\r\n\r\n2. <color=#569CD6><b>Logic:</b></color> <color=#4EC9B0>innerHTML</color>
    tells the browser to \"run any code found in this string,\" which allows hackers
    to sneak in `<script>` tags. <color=#DCDCAA>textContent</color> tells the browser
    \"this is just plain text,\" forcing it to ignore any malicious code and display
    it safely."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2100000, guid: 8b66bb805569de04b99b6e7e47b04014, type: 2}
  m_fontSharedMaterials: []
