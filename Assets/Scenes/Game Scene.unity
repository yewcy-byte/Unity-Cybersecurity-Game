  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=150%><b>Cross-Site Request Forgery (CSRF)</b></size>\n\n<color=#569CD6><b>Action:</b></color>
    Include a unique, unpredictable <color=#4EC9B0>csrf_token</color> as a hidden
    field in every sensitive form. Ensure the server validates that this token matches
    the one stored in the user\u2019s current session before processing the request.\n\n<color=#569CD6><b>Logic:</b></color>
    Without a token, a hacker can trick a logged-in user into clicking a malicious
    link that submits a \"ghost\" form to your server. By requiring a <color=#DCDCAA>csrf_token</color>,
    the server ensures the request actually originated from your real website, as
    an external attacker has no way of knowing or stealing that secret, one-time
    value."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2100000, guid: 8b66bb805569de04b99b6e7e47b04014, type: 2}
