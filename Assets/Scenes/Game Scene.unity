  m_text: '<color=#569CD6>String</color> sql = <color=#CE9178>"SELECT * FROM users
    WHERE user = ? AND pass = ?"</color>;

    <color=#4EC9B0>Statement</color> st
    = conn.<color=#DCDCAA>prepareStatement</color>(sql);

    st.<color=#DCDCAA>setString</color>(<color=#B5CEA8>1</color>,
    user);

    st.<color=#DCDCAA>setString</color>(<color=#B5CEA8>2</color>, pass);

    <color=#4EC9B0>ResultSet</color>
    rs = st.<color=#DCDCAA>executeQuery</color>();'
