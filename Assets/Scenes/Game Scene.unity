  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '<size=150%><b>JSON Web Token (JWT) Exploitation</b></size>


    <color=#569CD6><b>Action:</b></color>
    Replace <color=#4EC9B0>jwt.decode()</color> with <color=#DCDCAA>jwt.verify()</color>
    and provide a secret key. Ensure your server validates the signature of every
    incoming token before trusting its contents.


    <color=#569CD6><b>Logic:</b></color>
    <color=#4EC9B0>jwt.decode()</color> only translates the token''s data into readable
    text, which a hacker can easily manipulate using tools like Burp Suite. <color=#DCDCAA>jwt.verify()</color>
    performs a mathematical check using a secret key; if even one character in the
    token is changed, the "digital seal" breaks, and the server will instantly reject
    the tampered data.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2100000, guid: 8b66bb805569de04b99b6e7e47b04014, type: 2}
